{
  "name": "onlycmd-plugin",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./github": {
      "types": "./dist/github/index.d.ts",
      "default": "./dist/github/index.js"
    },
    "./jira": {
      "types": "./dist/jira/index.d.ts",
      "default": "./dist/jira/index.js"
    },
    "./x": {
      "types": "./dist/x/index.d.ts",
      "default": "./dist/x/index.js"
    },
    "./gws-drive": {
      "types": "./dist/gws-drive/index.d.ts",
      "default": "./dist/gws-drive/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:x": "vitest run src/x src/__tests__/x",
    "test:watch": "vitest",
    "test:verbose": "vitest run --reporter=verbose",
    "test:full": "X_INTEGRATION_WRITE=1 vitest run --reporter=verbose",
    "test:report": "vitest run --reporter=verbose 2>&1 | tee test-results.txt",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xdevplatform/xdk": "^0.5.0",
    "onlycmd": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^9.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
